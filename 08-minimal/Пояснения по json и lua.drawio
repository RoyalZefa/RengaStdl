        <mxCell id="2VlHA7ADcK374iz7z3bi-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;JSON:&lt;/div&gt;&quot;name&quot;: &quot;Dimensions&quot;&lt;div&gt;&quot;text&quot;: &quot;Габариты&quot;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Это объект, для которого перечислены свойства:&lt;/div&gt;&lt;div&gt;BaseWidth,&amp;nbsp;ShoulderHeight,&amp;nbsp;TopWidth,&amp;nbsp;TotalHeight,&amp;nbsp;Depth.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Это массив с свойствами, перечисленными выше.&lt;/div&gt;&lt;div&gt;&quot;params&quot;: [&lt;/div&gt;&lt;div&gt;...&lt;/div&gt;&lt;div&gt;]&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="560" x="134" y="330" as="geometry" />
