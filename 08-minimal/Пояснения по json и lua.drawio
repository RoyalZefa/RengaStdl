        <mxCell id="2VlHA7ADcK374iz7z3bi-66" edge="1" parent="1" source="2VlHA7ADcK374iz7z3bi-59" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="2VlHA7ADcK374iz7z3bi-61">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-59" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;&lt;div&gt;&lt;div&gt;local placement = Placement3D(&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Point3D(0, 0, 0),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Vector3D(0, 1, 0),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Vector3D(1, 0, 0)&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="256.5" x="67.5" y="2660" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-64" edge="1" parent="1" source="2VlHA7ADcK374iz7z3bi-60" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="2VlHA7ADcK374iz7z3bi-61">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-60" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;&lt;div&gt;&lt;div&gt;local placement = Placement3D(&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Point3D(0, 0, 0),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Vector3D(0, 0, 1),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; Vector3D(1, 0, 0)&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="256.5" x="450" y="2660" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Point3D(0, 0, 0) - где стоит профиль&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Vector3D(0, 1, 0) - куда идет выдавливание&lt;/div&gt;&lt;div&gt;Vector3D(1, 0, 0) - где у профиля &quot;право&quot;&lt;/div&gt;&lt;div&gt;placement - в него входит набор координат выше:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Placement3D(point, zAxisDirection, xAxisDirection)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Point3D&lt;/div&gt;&lt;div&gt;Vector3D для локальной оси Z&lt;/div&gt;&lt;div&gt;Vector3D для локальной оси X&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="406.5" x="185.5" y="2850" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-67" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Выдавливаем профиль на заданную глубину.&lt;/div&gt;&lt;div&gt;ExtrusionParameters(depth) означает: построить тело длиной depth&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;вдоль локальной оси Z placement-а.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;local solid = Extrude(profile, ExtrusionParameters(depth), placement)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="781.75" x="20.130000000000003" y="3070" as="geometry" />
        </mxCell>
