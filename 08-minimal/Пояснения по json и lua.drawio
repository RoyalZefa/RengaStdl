        <mxCell id="2VlHA7ADcK374iz7z3bi-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;local baseWidth = parameters.Dimensions.BaseWidth&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Создается переменная с именем&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;baseWidth, в которую записываются данные из json файла.&lt;/span&gt;&lt;/div&gt;" vertex="1">
