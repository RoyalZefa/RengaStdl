        <mxCell id="2VlHA7ADcK374iz7z3bi-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;LUA:&lt;/div&gt;&lt;div&gt;&lt;div&gt;Создаем полилинию по этим точкам.&lt;/div&gt;&lt;div&gt;Так как первая и последняя точки совпадают, контур получается замкнутым.&lt;/div&gt;&lt;div&gt;local profile = CreatePolyline2D(profilePoints)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="362" x="230" y="2280" as="geometry" />
        </mxCell>
        <mxCell id="2VlHA7ADcK374iz7z3bi-58" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
