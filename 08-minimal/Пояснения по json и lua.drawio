        <mxCell id="2VlHA7ADcK374iz7z3bi-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="&lt;div&gt;По итогу:&lt;/div&gt;shoulderHeight = 40&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;То, чем мы можем оперировать в lua файле.&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="390" x="376.5" y="1060" as="geometry" />
