        <mxCell id="2VlHA7ADcK374iz7z3bi-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontFamily=Georgia;" value="LUA:&lt;div&gt;local halfBaseWidth = baseWidth / 2&lt;/div&gt;&lt;div&gt;Создаем переменную с произвольным именем&amp;nbsp;halfBaseWidth, которому присваивается&amp;nbsp;baseWidth / 2&lt;/div&gt;&lt;div&gt;Получается так:&lt;/div&gt;&lt;div&gt;halfBaseWidth = 120/2&lt;/div&gt;&lt;div&gt;halfBaseWidth = 60&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="791" x="19" y="1210" as="geometry" />
